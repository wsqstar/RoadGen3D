{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadgen3d.local/schemas/template_patch.schema.json",
  "title": "RoadGen3D Template Patch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "operations"],
  "properties": {
    "schema_version": {
      "const": "roadgen3d_template_patch_v1"
    },
    "variant_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "min_strip_width_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_drive_lane_width_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_bus_lane_width_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_bike_lane_width_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_clear_sidewalk_width_m": { "type": "number", "exclusiveMinimum": 0 },
        "min_total_drive_lanes": { "type": "integer", "minimum": 0 },
        "require_bidirectional_drive_lanes": { "type": "boolean" }
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/resize_strip" },
          { "$ref": "#/$defs/update_strip" },
          { "$ref": "#/$defs/remove_strip" },
          { "$ref": "#/$defs/add_strip" },
          { "$ref": "#/$defs/replace_strips" },
          { "$ref": "#/$defs/add_functional_zone" },
          { "$ref": "#/$defs/upsert_functional_zone" },
          { "$ref": "#/$defs/remove_functional_zone" }
        ]
      }
    }
  },
  "$defs": {
    "centerline_target": {
      "type": "object",
      "properties": {
        "centerline_id": { "type": "string", "minLength": 1 },
        "centerline_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "all_centerlines": { "type": "boolean" },
        "selector": { "enum": ["all", "*", "all_centerlines"] },
        "target": {
          "type": "object",
          "properties": {
            "centerline_id": { "type": "string", "minLength": 1 },
            "centerline_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "all_centerlines": { "type": "boolean" },
            "selector": { "enum": ["all", "*", "all_centerlines"] }
          },
          "additionalProperties": false
        }
      }
    },
    "strip_zone": {
      "enum": ["left", "center", "right"]
    },
    "strip_kind": {
      "enum": [
        "drive_lane",
        "bus_lane",
        "bike_lane",
        "parking_lane",
        "median",
        "grass_belt",
        "shared_street_surface",
        "colored_pavement",
        "nearroad_buffer",
        "nearroad_furnishing",
        "clear_sidewalk",
        "farfromroad_buffer",
        "frontage_reserve"
      ]
    },
    "strip_direction": {
      "enum": ["forward", "reverse", "bidirectional", "none"]
    },
    "strip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zone", "kind", "width_m"],
      "properties": {
        "strip_id": { "type": "string", "minLength": 1 },
        "zone": { "$ref": "#/$defs/strip_zone" },
        "kind": { "$ref": "#/$defs/strip_kind" },
        "width_m": { "type": "number", "exclusiveMinimum": 0 },
        "direction": { "$ref": "#/$defs/strip_direction" },
        "order_index": { "type": "integer", "minimum": 0 }
      }
    },
    "resize_strip": {
      "allOf": [
        { "$ref": "#/$defs/centerline_target" },
        {
          "type": "object",
          "required": ["op", "strip_id", "width_m"],
          "properties": {
            "op": { "const": "resize_strip" },
            "strip_id": { "type": "string", "minLength": 1 },
            "width_m": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    },
    "update_strip": {
      "allOf": [
        { "$ref": "#/$defs/centerline_target" },
        {
          "type": "object",
          "required": ["op", "strip_id"],
          "properties": {
            "op": { "const": "update_strip" },
            "strip_id": { "type": "string", "minLength": 1 },
            "updates": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": false,
              "properties": {
                "zone": { "$ref": "#/$defs/strip_zone" },
                "kind": { "$ref": "#/$defs/strip_kind" },
                "width_m": { "type": "number", "exclusiveMinimum": 0 },
                "direction": { "$ref": "#/$defs/strip_direction" }
              }
            }
          }
        }
      ]
    },
    "remove_strip": {
      "allOf": [
        { "$ref": "#/$defs/centerline_target" },
        {
          "type": "object",
          "required": ["op", "strip_id"],
          "properties": {
            "op": { "const": "remove_strip" },
            "strip_id": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "add_strip": {
      "allOf": [
        { "$ref": "#/$defs/centerline_target" },
        {
          "type": "object",
          "required": ["op", "strip"],
          "properties": {
            "op": { "const": "add_strip" },
            "strip": { "$ref": "#/$defs/strip" },
            "before_strip_id": { "type": "string", "minLength": 1 },
            "after_strip_id": { "type": "string", "minLength": 1 },
            "order_index": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "replace_strips": {
      "allOf": [
        { "$ref": "#/$defs/centerline_target" },
        {
          "type": "object",
          "required": ["op", "strips"],
          "properties": {
            "op": { "const": "replace_strips" },
            "strips": {
              "type": "array",
              "items": { "$ref": "#/$defs/strip" },
              "minItems": 1
            }
          }
        }
      ]
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "zone_furniture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "x_px", "y_px"],
      "properties": {
        "instance_id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["bench", "lamp", "trash", "mailbox", "bollard", "sign", "hydrant", "bus_stop", "tree", "kiosk", "sculpture"]
        },
        "x_px": { "type": "number" },
        "y_px": { "type": "number" },
        "yaw_deg": { "type": "number" }
      }
    },
    "functional_zone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "points"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "kind": { "enum": ["plaza", "garden", "playground", "amphitheater", "outdoor_seating", "parking", "kiosk", "sculpture"] },
        "points": {
          "type": "array",
          "items": { "$ref": "#/$defs/point" },
          "minItems": 3
        },
        "furniture_instances": {
          "type": "array",
          "items": { "$ref": "#/$defs/zone_furniture" }
        }
      }
    },
    "add_functional_zone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "zone"],
      "properties": {
        "op": { "const": "add_functional_zone" },
        "zone": { "$ref": "#/$defs/functional_zone" }
      }
    },
    "upsert_functional_zone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "zone"],
      "properties": {
        "op": { "const": "upsert_functional_zone" },
        "zone": { "$ref": "#/$defs/functional_zone" }
      }
    },
    "remove_functional_zone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "zone_id"],
      "properties": {
        "op": { "const": "remove_functional_zone" },
        "zone_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
