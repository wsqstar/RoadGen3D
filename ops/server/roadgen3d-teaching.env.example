PYTHONPATH=/opt/roadgen3d/src:/opt/roadgen3d
MPLCONFIGDIR=/var/cache/roadgen3d/matplotlib
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

ROADGEN_DATABASE_URL=postgresql+psycopg://roadgen3d:CHANGE_ME@127.0.0.1:5432/roadgen3d
ROADGEN_REDIS_URL=redis://127.0.0.1:6379/0
ROADGEN_JOB_MODE=rq
ROADGEN_MAX_ACTIVE_JOBS_PER_USER=3
ROADGEN_JOB_TIMEOUT_SECONDS=1800

ROADGEN_OBJECT_STORE=local
ROADGEN_ARTIFACT_ROOT=/var/lib/roadgen3d/artifacts
ROADGEN_OSM_CACHE=/var/lib/roadgen3d/osm-cache

# This is the no-ML teaching profile: do not try to load CLIP/FAISS.
ROADGEN_ASSET_RETRIEVAL_MODE=curated_rule_pool
ROADGEN_RAG_MODE=disabled

ROADGEN_ALLOW_DEV_BOOTSTRAP=0
ROADGEN_BOOTSTRAP_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
ROADGEN_CORS_ORIGINS=https://roadgen.example.edu
