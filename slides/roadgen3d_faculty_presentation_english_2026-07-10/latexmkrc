# latexmk configuration for HKUST(GZ) UGOD Beamer slides.
# Build with XeLaTeX and make the reusable hkustgz-ugod-theme folder importable.
$pdf_mode = 5;            # 5 = xelatex
$xelatex = 'xelatex -interaction=nonstopmode -synctex=1 %O %S';

# Put the bundled reusable theme folder on the search path so \usetheme{hkustgzugod}
# (and its color sub-theme + elements) resolve without installing anything.
ensure_path('TEXINPUTS', './hkustgz-ugod-theme//');
