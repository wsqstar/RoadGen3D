% beamerthemehkustgzugod-elements.sty
% Theme author: 王世琦 (Shiqi Wang) — 香港科技大学（广州）社会枢纽 城市治理与设计学域
% 基于杨昊波 (Haobo Yang) 的 SUSTech elements 主题修改。
% 可复用排版宏与环境（基于标准 beamer 构件，键入 HKUST(GZ) UGOD 学术配色）。
% 由 beamerthemehkustgzugod.sty 在加载 color 主题之后引入，故可直接使用
% hkustgold / hkustblue / hkustgoldlt / hkustink 等颜色。
\ProvidesPackage{beamerthemehkustgzugod-elements}[2026/07/09 HKUST(GZ) UGOD themed elements (Madrid-based)]

\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{colortbl}
\RequirePackage{amsmath}

% --- 文字配色别名（强调=金 / 关键词=金 / 表头=主蓝）---------------------------
\colorlet{emph}{hkustgold}
\colorlet{kw}{hkustgold}
\colorlet{hdr}{hkustblue}

% --- 强调 / 高亮 -------------------------------------------------------------
\newcommand{\shl}[1]{\textbf{\textcolor{emph}{#1}}}        % 强调（金、粗）
\newcommand{\keyword}[1]{\textbf{\textcolor{kw}{#1}}}      % 关键词（金、粗）
\newcommand{\brandemph}[1]{\textcolor{emph}{#1}}             % 品牌强调（金、正体；避免中文斜体 warning）
\newcommand{\hlbox}[1]{\colorbox{hkustgoldlt!45}{#1}}      % 金黄底高亮（重要数字）

% --- 图与图注 ----------------------------------------------------------------
% \fitfigure{file}：限宽限高、保持比例，避免溢出
\newcommand{\fitfigure}[1]{\includegraphics[width=\linewidth,height=0.45\textheight,keepaspectratio]{#1}}
% 图注前缀（默认“图”，可用 \setfigureprefix 改为 Figure 等）
\newcommand{\figureprefix}{图}
\newcommand{\setfigureprefix}[1]{\renewcommand{\figureprefix}{#1}}
% \figcap{n}{文字} -> "图 n: 文字" — 自动换行并居中，标题始终在图下方
\newcommand{\figcap}[2]{\par\smallskip{\centering\footnotesize\color{hkustgrey}\mbox{\figureprefix~#1:}~#2\par}}

% --- 指标大数字 --------------------------------------------------------------
% \metric{100\%}{成功率}
\newcommand{\metric}[2]{%
  \begin{minipage}[t]{0.30\textwidth}\centering
    {\fontsize{22}{24}\selectfont\textbf{\textcolor{emph}{#1}}}\\[0.2em]
    {\small\color{hkustgrey}#2}
  \end{minipage}}

% --- 要点框 callout（金色 alertblock）----------------------------------------
\newenvironment{callout}[1][要点]{\begin{alertblock}{#1}}{\end{alertblock}}

% --- 文献证据标注系统（可复用）----------------------------------------------
% 用于区分：文献直接支撑 / AI 或讲者综合 / 研究缺口
% 用法：
%   \item \srcbadge{TrafficGAN} 城市决策需要前置评估...
%   \item \aibadge 这是跨文献的综合判断
%   \item \gapbadge 现有方法尚未解决...
%   \srcquote{no data about the impact...}{TrafficGAN, Abstract}
\newcommand{\srcbadge}[1]{\colorbox{hkustbluelt!25}{\tiny\color{hkustblue}\textbf{引：#1}}}
\newcommand{\aibadge}{\colorbox{hkustgoldbg!50}{\tiny\color{hkustgold}\textbf{综合}}}
\newcommand{\gapbadge}{\colorbox{hkustgold!20}{\tiny\color{hkustgold}\textbf{缺口}}}
\newcommand{\srcquote}[2]{%
  \begin{flushleft}
    {\scriptsize\color{hkustgrey}“#1”}\par
    {\scriptsize\color{hkustblue}—— #2}
  \end{flushleft}}

% --- 表格辅助 ----------------------------------------------------------------
\newcommand{\theadrow}{\rowcolor{hdr}}     % 表头底色行（主蓝）
\newcommand{\altrow}{\rowcolor{cardgrey}}  % 隔行浅灰
\newcommand{\thc}[1]{{\color{white}\bfseries #1}}

% --- 间距节律 ----------------------------------------------------------------
\newcommand{\tightgap}{\vspace{0.18em}}
\newcommand{\deckgap}{\vspace{0.45em}}

% --- 分区宽度 ----------------------------------------------------------------
\newcommand{\zonetext}{0.55\textwidth}
\newcommand{\zonefig}{0.42\textwidth}
\newcommand{\zonehalf}{0.48\textwidth}

% --- 章节分隔页（Part 编号 + 标题 + 一句话主旨）------------------------------
% 在每个 \section 之前用 \renewcommand{\secblurb}{...} 设置本节主旨。
\newcommand{\secblurb}{}
\AtBeginSection[]{%
  \begin{frame}[plain,c]
    \centering
    {\color{hkustgrey}\large Part~\thesection}\\[0.6em]
    {\color{hkustblue}\Huge\bfseries\insertsectionhead}\\[0.8em]
    {\color{emph}\rule{2cm}{2pt}}\\[1.0em]
    \begin{minipage}{0.78\textwidth}\centering
      {\color{hkustink}\normalsize\secblurb}
    \end{minipage}
  \end{frame}}

\mode<all>
