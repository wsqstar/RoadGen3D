# 复制为 .env 并填入真实值（勿将 .env 提交到 Git）
# GRAPHRAG_API_KEY：兼容 OpenAI 的网关或 OpenAI 官网密钥，只写 sk-... 本身
# 与 settings.yaml 中 api_base 对齐
GRAPHRAG_API_BASE=https://api.linkapi.org/v1
GRAPHRAG_API_KEY=sk-your-api-key-here
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=your-neo4j-user
NEO4J_PASSWORD=your-neo4j-password
